generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  name         String?
  email        String        @unique
  passwordHash String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  gymProfile   GymProfile?
  exercises    Exercise[]
  workoutDays  WorkoutDay[]
  workoutLogs  WorkoutLog[]
}

model ExerciseCatalogItem {
  id              String     @id @default(cuid())
  slug            String     @unique
  name            String
  muscleGroup     String?
  imageUrl        String?
  defaultWeightKg Float?
  note            String?
  sortOrder       Int        @default(0)
  isActive        Boolean    @default(true)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  exercises       Exercise[]
  workoutDayExercises WorkoutDayExercise[]
  workoutExerciseLogs WorkoutExerciseLog[]
  workoutTemplateExercises WorkoutTemplateExercise[]

  @@index([isActive, sortOrder])
  @@index([muscleGroup, sortOrder])
}

model GymProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  displayName String?
  goal        String?
  heightCm    Int?
  weightKg    Float?
  timezone    String   @default("Asia/Bangkok")
  appliedWorkoutTemplateId String?
  appliedWorkoutTemplate   WorkoutTemplate? @relation(fields: [appliedWorkoutTemplateId], references: [id], onDelete: SetNull)
  appliedWorkoutTemplateAt DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Exercise {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  catalogItemId   String?
  catalogItem     ExerciseCatalogItem? @relation(fields: [catalogItemId], references: [id], onDelete: SetNull)

  name            String
  muscleGroup     String?
  imageUrl        String?
  currentWeightKg Float?
  note            String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId, muscleGroup])
  @@index([catalogItemId])
  @@unique([userId, catalogItemId])
}

model WorkoutDay {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  dayOfWeek  Int
  title      String
  isRestDay  Boolean  @default(false)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  exercises  WorkoutDayExercise[]

  @@unique([userId, dayOfWeek])
  @@index([userId, dayOfWeek])
}

model WorkoutDayExercise {
  id           String        @id @default(cuid())

  workoutDayId String
  workoutDay   WorkoutDay    @relation(fields: [workoutDayId], references: [id], onDelete: Cascade)

  catalogItemId String
  catalogItem   ExerciseCatalogItem @relation(fields: [catalogItemId], references: [id], onDelete: Restrict)

  orderIndex   Int           @default(0)
  note         String?

  sets         WorkoutPlanSet[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([workoutDayId, orderIndex])
  @@index([catalogItemId])
}

model WorkoutPlanSet {
  id                   String             @id @default(cuid())

  workoutDayExerciseId  String
  workoutDayExercise    WorkoutDayExercise @relation(fields: [workoutDayExerciseId], references: [id], onDelete: Cascade)

  setIndex             Int
  intensityPercent     Int?
  targetReps           Int?
  targetWeightKg       Float?

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([workoutDayExerciseId, setIndex])
}

model WorkoutLog {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  workoutDate   DateTime
  dayOfWeek     Int
  title         String?

  startedAt     DateTime @default(now())
  completedAt   DateTime?

  exerciseLogs  WorkoutExerciseLog[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId, workoutDate])
  @@index([userId, dayOfWeek])
}

model WorkoutExerciseLog {
  id            String           @id @default(cuid())

  workoutLogId  String
  workoutLog    WorkoutLog       @relation(fields: [workoutLogId], references: [id], onDelete: Cascade)

  catalogItemId String?
  catalogItem   ExerciseCatalogItem? @relation(fields: [catalogItemId], references: [id], onDelete: SetNull)
  exerciseName  String
  muscleGroup   String?
  imageUrl      String?

  orderIndex    Int              @default(0)
  isCompleted   Boolean          @default(false)

  setLogs       WorkoutSetLog[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([workoutLogId, orderIndex])
  @@index([catalogItemId])
}

model WorkoutSetLog {
  id                   String             @id @default(cuid())

  workoutExerciseLogId  String
  workoutExerciseLog    WorkoutExerciseLog @relation(fields: [workoutExerciseLogId], references: [id], onDelete: Cascade)

  setIndex             Int
  intensityPercent     Int?
  targetReps           Int?
  targetWeightKg       Float?

  actualReps           Int?
  actualWeightKg       Float?
  isCompleted          Boolean          @default(false)
  note                 String?

  completedAt          DateTime?

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([workoutExerciseLogId, setIndex])
}

model WorkoutTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  sessionsPerWeek Int  @default(0)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  days        WorkoutTemplateDay[]
  gymProfiles GymProfile[]

  @@index([isActive, sortOrder])
}

model WorkoutTemplateDay {
  id                String   @id @default(cuid())
  workoutTemplateId String
  workoutTemplate   WorkoutTemplate @relation(fields: [workoutTemplateId], references: [id], onDelete: Cascade)
  dayOfWeek         Int
  title             String
  isRestDay         Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  exercises         WorkoutTemplateExercise[]

  @@unique([workoutTemplateId, dayOfWeek])
  @@index([workoutTemplateId, dayOfWeek])
}

model WorkoutTemplateExercise {
  id                   String   @id @default(cuid())
  workoutTemplateDayId String
  workoutTemplateDay   WorkoutTemplateDay @relation(fields: [workoutTemplateDayId], references: [id], onDelete: Cascade)
  catalogItemId        String
  catalogItem          ExerciseCatalogItem @relation(fields: [catalogItemId], references: [id], onDelete: Restrict)
  orderIndex           Int      @default(0)
  note                 String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  sets                 WorkoutTemplateSet[]

  @@index([workoutTemplateDayId, orderIndex])
  @@index([catalogItemId])
}

model WorkoutTemplateSet {
  id                       String   @id @default(cuid())
  workoutTemplateExerciseId String
  workoutTemplateExercise  WorkoutTemplateExercise @relation(fields: [workoutTemplateExerciseId], references: [id], onDelete: Cascade)
  setIndex                Int
  intensityPercent        Int?
  targetReps              Int?
  targetWeightKg          Float?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([workoutTemplateExerciseId, setIndex])
}
